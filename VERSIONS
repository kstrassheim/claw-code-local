# claw-code-local version pins — single source of truth.
# Read by .github/workflows/validate.yml and deploy.yml.
# Bump a value here and a PR / merge will rebuild the image with it.

# Upstream openclaw base image (FROM in builder/Dockerfile).
# Tag matches https://github.com/openclaw/openclaw releases. The deploy /
# validate workflows pull ghcr.io/openclaw/openclaw:<this minus v-prefix>
# and re-tag it locally as openclaw-base:<this with v-prefix>.
OPENCLAW_UPSTREAM=v2026.5.7
OPENCLAW_VERSION=v2026.5.7.15

# Tools baked into the openclaw image.
GH_CLI_VERSION=2.92.0
GITHUB_MCP_SERVER_VERSION=0.18.0
GLAB_VERSION=0.49.0
GITLAB_MCP_VERSION=0.7.0
TERRAFORM_VERSION=1.10.0
TERRAFORM_MCP_VERSION=0.9.2
CODE_SERVER_VERSION=0.22.1
AWS_CLI_VERSION=2.22.0
GCLOUD_VERSION=497.0.0
ALIYUN_CLI_VERSION=3.82.0

# Third-party images mirrored into the local registry.
OLLAMA_VERSION=0.5.4
OPEN_WEBUI_VERSION=0.4.12