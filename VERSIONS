# claw-code-local version pins — single source of truth.
# Read by .github/workflows/validate.yml and deploy.yml.
# Bump a value here and a PR / merge will rebuild the image with it.

# Upstream openclaw base image (FROM in builder/Dockerfile).
# Tag matches https://github.com/openclaw/openclaw releases. The deploy /
# validate workflows pull ghcr.io/openclaw/openclaw:<this minus v-prefix>
# and re-tag it locally as openclaw-base:<this with v-prefix>.
OPENCLAW_UPSTREAM=v2026.5.12
OPENCLAW_VERSION=v2026.5.12.33

# Tools baked into the openclaw image.
# All values mirror claw-code/VERSIONS (the Azure sibling) — known-working
# combinations against the corresponding tools' GitHub Releases / vendor
# CDNs. Bump deliberately; verify the artifact URL exists for arm64
# before pushing (the build pulls these from upstream CDNs at image
# build time, so a wrong value 404s mid-build).
GH_CLI_VERSION=2.92.0
GITHUB_MCP_SERVER_VERSION=1.0.3
GLAB_VERSION=1.97.0
GITLAB_MCP_VERSION=0.7.0
TERRAFORM_VERSION=1.13.0
TERRAFORM_MCP_VERSION=0.5.2
CODE_SERVER_VERSION=4.118.0
AWS_CLI_VERSION=2.34.45
GCLOUD_VERSION=567.0.0
ALIYUN_CLI_VERSION=3.3.14